# MongoDB Atlas connection string (required)
ACGC_MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
ACGC_MONGO_DB=acgc

# gRPC server port
ACGC_GRPC_PORT=50051

# Main LLM (for agent reasoning)
# ACGC_LLM_API_KEY=sk-...
# ACGC_LLM_MODEL=gpt-5
# ACGC_LLM_PROVIDER=openai

# Summarizer LLM for branch compression (optional — falls back to simple compressor)
# ACGC_SUMMARIZER_API_KEY=sk-...
# ACGC_SUMMARIZER_MODEL=gpt-4o-mini

# GC policy tuning
# ACGC_TOKEN_BUDGET=6000
# ACGC_STALE_TURNS=15
# ACGC_MAX_TREE_DEPTH=10
# ACGC_MAX_CHILDREN=50
# ACGC_LOW_RELEVANCE=0.30
# IMPORTANT: keep ACGC_GC_DECISION_SWEEP_FLOOR strictly below ACGC_LOW_RELEVANCE,
# otherwise bare NodeDecision nodes become permanently un-sweepable.
# ACGC_GC_DECISION_SWEEP_FLOOR=0.20
# Phase 2 GC triggers — fire on dense short-token sessions, not just budget saturation.
# ACGC_GC_MAX_ACTIVE_NODES=25
# ACGC_GC_SWEEP_HEADROOM_RATIO=0.60

# Semantic scoring (HNSW + embeddings)
# Off by default to preserve v1 behavior. Turn on once you have embedding credit.
# ACGC_SEMANTIC_ENABLED=true
# ACGC_SEMANTIC_WEIGHT=0.20
# ACGC_HNSW_TOP_K_AT_COMPILE=12
# ACGC_ARCHIVE_SEMANTIC_TOP_K=12
# ACGC_HNSW_M=16
# ACGC_HNSW_EF_SEARCH=50
# ACGC_EMBED_PROVIDER=openai
# ACGC_EMBED_MODEL=text-embedding-3-small
# ACGC_EMBED_DIM=1536
# Defaults to ACGC_LLM_API_KEY if unset.
# ACGC_EMBED_API_KEY=sk-...

# When true, Run responses include optional latency_breakdown (compile phases + llm_ms).
# Default off for minimal overhead in production.
# ACGC_LATENCY_BREAKDOWN=false
